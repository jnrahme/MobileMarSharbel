default_platform(:ios)

platform :ios do
  def app_identifier_value
    "com.rammyinn.saintcharbel"
  end

  def xcodeproj_path
    "SaintCharbelApp.xcodeproj"
  end

  def target_name
    "SaintCharbelApp"
  end

  def marketing_version_value
    get_version_number(
      xcodeproj: xcodeproj_path,
      target: target_name
    )
  end

  def api_key_if_available
    return nil unless ENV["APPSTORE_KEY_ID"] && ENV["APPSTORE_ISSUER_ID"]

    app_store_connect_api_key(
      key_id: ENV["APPSTORE_KEY_ID"],
      issuer_id: ENV["APPSTORE_ISSUER_ID"],
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['APPSTORE_KEY_ID']}.p8")
    )
  end

  def signing_team_value
    ENV["IOS_DEVELOPMENT_TEAM"] || ENV["FASTLANE_TEAM_ID"]
  end

  def release_build_options
    team = signing_team_value
    xcargs_parts = ["-allowProvisioningUpdates"]
    xcargs_parts << "DEVELOPMENT_TEAM=#{team}" if team && !team.empty?

    options = {
      scheme: target_name,
      export_method: "app-store",
      xcargs: xcargs_parts.join(" "),
      output_directory: "build/release",
      output_name: "SaintCharbelApp",
      clean: true
    }
    options[:export_team_id] = team if team && !team.empty?
    options
  end

  desc "Create a signed local release archive/IPA"
  lane :release_build do
    setup_ci if ENV["CI"] == "true"
    build_app(release_build_options)
  end

  desc "Build and upload the current release to TestFlight"
  lane :beta do
    setup_ci if ENV["CI"] == "true"

    api_key = api_key_if_available
    version = marketing_version_value
    current_build_number = get_build_number(xcodeproj: xcodeproj_path).to_i
    next_build_number = current_build_number + 1

    if api_key
      begin
        remote_build_number = latest_testflight_build_number(
          api_key: api_key,
          app_identifier: app_identifier_value,
          version: version,
          initial_build_number: current_build_number
        ).to_i
        next_build_number = [next_build_number, remote_build_number + 1].max
      rescue => e
        UI.important("Could not determine latest TestFlight build number: #{e}")
      end
    end

    UI.message("Using build number #{next_build_number} for version #{version}")
    increment_build_number(
      xcodeproj: xcodeproj_path,
      build_number: next_build_number
    )

    build_app(release_build_options)

    upload_to_testflight(
      skip_waiting_for_build_processing: false,
      api_key: api_key
    )
  end

  desc "Create the App Store Connect app record"
  lane :create_app do |options|
    produce(
      app_identifier: app_identifier_value,
      app_name: "Saint Charbel Mobile",
      language: "en-US",
      app_version: options[:version] || marketing_version_value,
      sku: "saintcharbel-ios",
      team_id: ENV["FASTLANE_TEAM_ID"]
    )
  end

  desc "Upload localized metadata and screenshots"
  lane :metadata do |options|
    api_key = api_key_if_available
    version = options[:version] || marketing_version_value

    deliver(
      app_identifier: app_identifier_value,
      app_version: version,
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: false,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      force: true,
      api_key: api_key
    )
  end

  desc "Submit the selected version for App Review"
  lane :submit_review do |options|
    api_key = api_key_if_available
    version = options[:version] || marketing_version_value
    build_number = options[:build_number]

    if (build_number.nil? || build_number.to_s.strip.empty?) && api_key
      begin
        build_number = latest_testflight_build_number(
          api_key: api_key,
          app_identifier: app_identifier_value,
          version: version
        )
      rescue => e
        UI.user_error!("Could not determine latest TestFlight build number for v#{version}: #{e}")
      end
    end

    if build_number.nil? || build_number.to_s.strip.empty?
      UI.user_error!("Missing build number. Provide build_number:<N> or configure APPSTORE_* API key env vars.")
    end

    UI.message("Submitting App Store version v#{version} with build #{build_number}")

    deliver(
      app_identifier: app_identifier_value,
      app_version: version,
      build_number: build_number.to_s,
      submit_for_review: true,
      automatic_release: false,
      skip_binary_upload: true,
      skip_screenshots: options.key?(:skip_screenshots) ? options[:skip_screenshots] : true,
      skip_metadata: options.key?(:skip_metadata) ? options[:skip_metadata] : true,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      force: true,
      api_key: api_key,
      submission_information: {
        export_compliance_uses_encryption: false,
        export_compliance_encryption_updated: false
      }
    )
  end
end
